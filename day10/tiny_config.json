{
    "model": {
        "dim": 288,
        "n_layers": 6,
        "n_heads": 6,
        "max_seq_len": 256,
        "vocab_size": 32000,
        "multiple_of": 32,
        "norm_eps": 1e-5,
        "hidden_dim": null
    },
    "training": {
        "batch_size": 32,
        "learning_rate": 3e-4,
        "max_iters": 10000,
        "warmup_iters": 500,
        "lr_decay_iters": 10000,
        "min_lr": 3e-5,
        "weight_decay": 0.1,
        "grad_clip": 1.0,
        "save_interval": 500,
        "eval_interval": 100,
        "log_interval": 10
    },
    "data": {
        "data_path": "./data",
        "tokenizer_path": "./tokenizer.model"
    },
    "checkpoint": {
        "checkpoint_dir": "./checkpoints",
        "resume": null
    }
}
